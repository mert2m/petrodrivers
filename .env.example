# PetroDrivers environment — copy to .env and fill. Validated at boot by src/config/env.ts (Zod).
# EXPO_PUBLIC_* vars are embedded in the client bundle (NOT secret). Real secrets stay server-side.

# --- Supabase (client) ---
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# --- Mapbox ---
# PUBLIC token (pk.*) used by the map at runtime.
EXPO_PUBLIC_MAPBOX_PUBLIC_TOKEN=pk.YOUR_PUBLIC_TOKEN
# SECRET download token (sk.*) — build-time only, consumed by app.config.ts. Do NOT prefix EXPO_PUBLIC_.
MAPBOX_DOWNLOAD_TOKEN=sk.YOUR_DOWNLOAD_TOKEN

# --- Weather proxy (Supabase Edge Function; never call providers directly from the client) ---
EXPO_PUBLIC_WEATHER_PROXY_URL=https://YOUR_PROJECT.supabase.co/functions/v1/weather-proxy

# --- Sentry (crash reporting behind a flag) ---
EXPO_PUBLIC_SENTRY_ENABLED=false
EXPO_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Analytics ---
EXPO_PUBLIC_ANALYTICS_ENABLED=false

# --- App env ---
EXPO_PUBLIC_APP_ENV=development
